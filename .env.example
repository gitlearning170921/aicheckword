# LLM 配置 (选择一种)
# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
# 如使用国内代理，修改为代理地址，如: https://api.openai-proxy.com/v1

# 模型配置
LLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# 向量库配置
CHROMA_PERSIST_DIR=./knowledge_store

# 文档分块配置
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# API服务配置
API_HOST=0.0.0.0
API_PORT=8000
