# LLM 配置 (选择一种)
# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
# 如使用国内代理，修改为代理地址，如: https://api.openai-proxy.com/v1

# DeepSeek（OpenAI 兼容，provider=deepseek）
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# 若报错 cl100k_base.tiktoken / ProxyError/SSLEOFError：应用会自动对 openaipublic.blob.core.windows.net 设 NO_PROXY；仍失败时可设 TIKTOKEN_CACHE_DIR 指向已下载的编码目录（见文档）
# 若报错 404 Not Found / event_id：检查 1) Base URL 为 https://api.deepseek.com/v1 且无多余路径；2) 模型名为 deepseek-chat 或 deepseek-chat-v2 等当前支持型号；3) API Key 有效且未过期

# 零一万物（OpenAI 兼容，provider=lingyi）
# LINGYI_API_KEY=
# LINGYI_BASE_URL=https://api.lingyiwanwu.com/v1

# Google Gemini（provider=gemini，二选一）
# GEMINI_API_KEY=
# GOOGLE_API_KEY=

# 阿里通义千问 DashScope（provider=tongyi）
# DASHSCOPE_API_KEY=
# 若出现 404 / Not Found / event_id：检查 API Key、模型名（如 qwen-plus）及网络

# 百度文心千帆（provider=baidu）
# QIANFAN_AK=
# QIANFAN_SK=

# 所有 AI 服务通用：HTTP 行为（侧栏「不校验 SSL」「不使用系统代理」也可配置并持久化）
# LLM_VERIFY_SSL=true
# LLM_TRUST_ENV=true

# Cursor Agent（可选）
# CURSOR_API_KEY=
# CURSOR_API_BASE=https://api.cursor.com
# CURSOR_REPOSITORY=
# 若出现 404 Not Found：检查基地址为 https://api.cursor.com、仓库地址与分支正确、API Key 有效

# 模型配置
# LLM_MODEL=gpt-4o
# provider=gemini 时可用 gemini-1.5-flash
# provider=tongyi 时可用 qwen-plus
# provider=deepseek 时可用 deepseek-chat
LLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# 向量库配置
CHROMA_PERSIST_DIR=./knowledge_store

# 文档分块配置
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# 训练时嵌入请求重试（出现「远程主机强制关闭连接」WinError 10054 时可调大）
# EMBEDDING_MAX_RETRIES=3
# EMBEDDING_RETRY_DELAY_SEC=2.0

# 大文件训练：块数超过阈值时自动缩小每批数量，避免训练到一半超时/断连
# EMBEDDING_LARGE_FILE_THRESHOLD=60
# EMBEDDING_LARGE_FILE_BATCH_SIZE=12

# API服务配置
API_HOST=0.0.0.0
API_PORT=8000

# 金山文档开放平台（第三步审核时可通过链接拉取正文，需在 https://developer.kdocs.cn 创建应用）
# KDOCS_APP_ID=
# KDOCS_APP_KEY=

# MySQL 数据库（配置与操作记录）
MYSQL_HOST=10.26.1.221
MYSQL_PORT=13306
MYSQL_DATABASE=aicheckword
MYSQL_USER=root
MYSQL_PASSWORD=mysql170921
MYSQL_CHARSET=utf8mb4
