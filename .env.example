# =============================================================================
# aicheckword 环境变量模板（与 config/settings.py 字段一致）
# 用法：复制本文件为 .env 后按需取消注释并填写；未启用的项保持注释即可。
# 迁机：至少保证 MYSQL_* 可连库；其余可在 Web「系统配置」写入数据库后覆盖本处取值。
# =============================================================================

# -----------------------------------------------------------------------------
# MySQL（必填：配置与操作记录、知识库元数据等）
# -----------------------------------------------------------------------------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=aicheckword
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_CHARSET=utf8mb4

# -----------------------------------------------------------------------------
# AI 服务提供方：ollama | openai | deepseek | lingyi | gemini | tongyi | baidu | cursor
# 与下方各区块密钥配套；未使用的 provider 保持其区块为注释即可。
# -----------------------------------------------------------------------------
PROVIDER=ollama

# --- Ollama（本地，默认推荐冷启动）---
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5
EMBEDDING_MODEL=nomic-embed-text
# 扫描件 PDF 的 AI OCR 专用多模态模型（留空则与 LLM_MODEL 相同）。示例：qwen2.5vl、llava
# PDF_OCR_LLM_MODEL=

# --- OpenAI（将 PROVIDER 改为 openai 后取消注释并填写）---
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small
# PDF_OCR_LLM_MODEL=gpt-4o-mini

# --- DeepSeek（OpenAI 兼容，PROVIDER=deepseek）---
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat
# 向量化仍走 Ollama，请保留上方 OLLAMA_* 与 EMBEDDING_MODEL
# 扫描件 PDF：DeepSeek Chat 不支持传图 OCR，程序会用下方 DASHSCOPE_API_KEY 调通义 VL 逐页识别。
# DASHSCOPE_API_KEY=（与通义块相同，阿里云 DashScope）
# 可选：显式指定 VL 模型；留空则代码默认 qwen-vl-plus（一般够用），复杂稿可试 qwen-vl-max
# PDF_OCR_LLM_MODEL=qwen-vl-plus

# --- 零一万物（OpenAI 兼容，PROVIDER=lingyi）---
# LINGYI_API_KEY=
# LINGYI_BASE_URL=https://api.lingyiwanwu.com/v1

# --- Google Gemini（PROVIDER=gemini；二选一密钥）---
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# LLM_MODEL=gemini-1.5-flash

# --- 阿里通义 DashScope（PROVIDER=tongyi）---
# DASHSCOPE_API_KEY=
# LLM_MODEL=qwen-plus
# 扫描件 PDF（文本层为空）：侧栏「PDF OCR 模型」或此处；须为 VL 系列，勿填纯文本模型名。
# 推荐 PDF_OCR_LLM_MODEL=qwen-vl-plus（成本/速度均衡）；识别仍差时再试 qwen-vl-max。
# PDF_OCR_LLM_MODEL=qwen-vl-plus

# --- 百度文心千帆（PROVIDER=baidu）---
# QIANFAN_AK=
# QIANFAN_SK=
# LLM_MODEL=ERNIE-Bot-4

# --- Cursor Agent（PROVIDER=cursor）---
# CURSOR_API_KEY=
# CURSOR_API_BASE=https://api.cursor.com
# CURSOR_REPOSITORY=
# CURSOR_REF=main
# CURSOR_EMBEDDING=ollama

# 所有 AI 服务 HTTP 行为（与侧栏「不校验 SSL / 不使用系统代理」一致，可写入库覆盖）
# LLM_VERIFY_SSL=true
# LLM_TRUST_ENV=true
# 兼容旧列名（保存配置时会与上一项同步，一般不必单独设置）
# CURSOR_VERIFY_SSL=true
# CURSOR_TRUST_ENV=true

# -----------------------------------------------------------------------------
# 向量库与分块（与 Settings 一致）
# -----------------------------------------------------------------------------
CHROMA_PERSIST_DIR=./knowledge_store
# CHROMA_SERVER_HOST=
# CHROMA_SERVER_PORT=8000
# CHROMA_SERVER_SSL=false
# CHROMA_SERVER_HEADERS_JSON=

CHUNK_SIZE=1000
CHUNK_OVERLAP=200
# EMBEDDING_MAX_RETRIES=3
# EMBEDDING_RETRY_DELAY_SEC=2.0
# EMBEDDING_LARGE_FILE_THRESHOLD=60
# EMBEDDING_LARGE_FILE_BATCH_SIZE=12
# EMBEDDING_STREAMLIT_CHUNK_THRESHOLD=48
# EMBEDDING_STREAMLIT_BATCHES_PER_RERUN=1

# -----------------------------------------------------------------------------
# 审核稳定性（多文件 / DeepSeek 等，一般保留默认即可）
# -----------------------------------------------------------------------------
# REVIEW_LLM_MIN_INTERVAL_SEC=0
# REVIEW_DEEPSEEK_CHROMA_FETCH_CAP=96
# REVIEW_DEEPSEEK_TARGET_CAP=64
# REVIEW_BATCH_SKIP_LLM_SUMMARY=true
# REVIEW_DEEPSEEK_INTER_DOC_SLEEP_SEC=0
# REVIEW_BATCH_INTER_DOC_SLEEP_SEC=0.35

# 审核性能日志（或进程环境 AUDIT_PERF_LOG=1）
# AUDIT_PERF_LOG=false
# ASYNC_CORRECTION_KB_FEED=true

# -----------------------------------------------------------------------------
# FastAPI 与本地目录
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
TRAINING_DOCS_DIR=./training_docs
UPLOADS_DIR=./uploads

# 兼容旧项（一般不必改）
# DB_PATH=./aicheckword.db

# -----------------------------------------------------------------------------
# 金山文档开放平台（可选：通过链接拉取正文）
# -----------------------------------------------------------------------------
# KDOCS_APP_ID=
# KDOCS_APP_KEY=

# -----------------------------------------------------------------------------
# 可选：与本仓库代码读取方式一致的环境变量（不在 Settings 类中）
# -----------------------------------------------------------------------------
# tiktoken 离线缓存目录（cl100k_base 等；内网/代理异常时可设）
# TIKTOKEN_CACHE_DIR=
# 训练旧版 .doc 时：LibreOffice / WPS（仅 document_loader 读取，见 README）
# LIBREOFFICE_PATH=
# WPS_PATH=
