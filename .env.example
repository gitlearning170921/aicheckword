# LLM 配置 (选择一种)
# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
# 如使用国内代理，修改为代理地址，如: https://api.openai-proxy.com/v1

# Cursor Agent（可选）
# CURSOR_API_KEY=
# CURSOR_API_BASE=https://api.cursor.com
# CURSOR_REPOSITORY=
# 代理/证书异常导致 SSL EOF 时可设为 false
# CURSOR_VERIFY_SSL=true

# 模型配置
LLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# 向量库配置
CHROMA_PERSIST_DIR=./knowledge_store

# 文档分块配置
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# API服务配置
API_HOST=0.0.0.0
API_PORT=8000

# 金山文档开放平台（第三步审核时可通过链接拉取正文，需在 https://developer.kdocs.cn 创建应用）
# KDOCS_APP_ID=
# KDOCS_APP_KEY=

# MySQL 数据库（配置与操作记录）
MYSQL_HOST=10.26.1.221
MYSQL_PORT=13306
MYSQL_DATABASE=aicheckword
MYSQL_USER=root
MYSQL_PASSWORD=mysql170921
MYSQL_CHARSET=utf8mb4
